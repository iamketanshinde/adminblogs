<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyBlog</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background: #f8f9fa;
        }

        html {
            scroll-behavior: smooth;
        }

        section {
            scroll-margin-top: 80px;
        }

        .hero {
            background: linear-gradient(135deg, #0d6efd, #6610f2);
            color: white;
            padding: 80px 0;
        }

        .blog-card {
            transition: .3s;
            border-radius: 15px;
        }

        .blog-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        }

        .blog-img {
            height: 200px;
            object-fit: cover;
        }
    </style>
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">MyBlog</a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- LEFT MENU -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#blogs">Articles</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#about">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 align-items-center">

                    <% if (!user) { %>

                        <a href="/signin" class="btn btn-outline-light btn-sm">Sign In</a>
                        <a href="/signup" class="btn btn-light btn-sm">Sign Up</a>

                        <% } else { %>

                            <% if (user.role==="ADMIN" ) { %>
                                <a href="/admin/dashboard" class="btn btn-warning btn-sm">Dashboard</a>
                                <a href="/admin/dashboard/add" class="btn btn-primary btn-sm">Add Blog</a>
                                <% } else { %>
                                    <a href="/" class="btn btn-success btn-sm">Home</a>
                                    <% } %>

                                        <a href="/logout" class="btn btn-danger btn-sm">Logout</a>

                                        <% } %>

                                            <!-- ✅ NEW ADMIN BUTTON (always visible) -->
                                            <a href="/admin" class="btn btn-outline-warning btn-sm ms-2">
                                                Admin
                                            </a>

                </div>

            </div>
        </div>
    </nav>

    <!-- ================= HERO ================= -->
    <section class="hero text-center">
        <div class="container">
            <h1 class="fw-bold display-5">Welcome to MyBlog</h1>
            <p class="lead mt-3">Read articles, explore ideas, and share knowledge.</p>
        </div>
    </section>

    <!-- ================= BLOG SECTION ================= -->
    <div class="container my-5" id="blogs">

        <h2 class="fw-bold mb-4 text-center">Latest Articles</h2>

        <% if(blogs && blogs.length> 0){ %>

            <div class="row g-4">

                <% blogs.forEach(blog=> { %>

                    <div class="col-12 col-sm-6 col-lg-4">
                        <div class="card blog-card h-100 shadow-sm">

                            <% if(blog.image){ %>
                                <img src="<%= blog.image %>" class="blog-img card-img-top">
                                <% } else { %>
                                    <img src="https://via.placeholder.com/500x300?text=No+Image"
                                        class="blog-img card-img-top">
                                    <% } %>

                                        <div class="card-body d-flex flex-column">

                                            <h5 class="fw-bold">
                                                <%= blog.title %>
                                            </h5>

                                            <small class="text-muted mb-2">By <%= blog.author %></small>

                                            <p class="flex-grow-1">
                                                <%= blog.content.length> 120
                                                    ? blog.content.slice(0,120) + "..."
                                                    : blog.content %>
                                            </p>

                                            <a href="/admin/dashboard/<%= blog._id %>" class="btn btn-primary mt-auto">
                                                Read Article
                                            </a>

                                        </div>
                        </div>
                    </div>

                    <% }) %>

            </div>

            <% } else { %>

                <div class="text-center py-5">
                    <h4>No Articles Available</h4>
                </div>

                <% } %>

    </div>

    <!-- ================= ABOUT ================= -->
    <section id="about" class="bg-light py-5">
        <div class="container text-center">
            <h2 class="fw-bold mb-4">About Us</h2>
            <p>
                Welcome to MyBlog! This platform is built to share knowledge, ideas, and experiences.
            </p>
        </div>
    </section>

    <!-- ================= CONTACT ================= -->
    <section id="contact" class="py-5">
        <div class="container">

            <h2 class="text-center fw-bold mb-4">Contact Us</h2>

            <div class="row justify-content-center">
                <div class="col-md-6">

                    <div class="card p-4 shadow-sm">
                        <form action="/contact" method="POST">

                            <input type="text" name="name" class="form-control mb-3" placeholder="Your Name" required>

                            <input type="email" name="email" class="form-control mb-3" placeholder="Your Email"
                                required>

                            <textarea name="message" class="form-control mb-3" rows="4" placeholder="Message"
                                required></textarea>

                            <button class="btn btn-primary w-100">Send Message</button>

                        </form>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <!-- ================= SOCIAL ================= -->
    <div class="text-center mb-4">
        <a href="https://github.com" target="_blank" class="me-3 fs-4"><i class="bi bi-github"></i></a>
        <a href="https://instagram.com" target="_blank" class="me-3 fs-4"><i class="bi bi-instagram"></i></a>
        <a href="https://twitter.com" target="_blank" class="me-3 fs-4"><i class="bi bi-twitter"></i></a>
        <a href="https://facebook.com" target="_blank" class="fs-4"><i class="bi bi-facebook"></i></a>
    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="bg-dark text-white text-center py-3">
        <small>© 2026 MyBlog | All Rights Reserved</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>