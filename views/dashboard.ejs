<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard For Admin</title>

    <link rel="stylesheet" href="/css/style.css">
    <%- include('partials/head.ejs') %>
</head>

<body>

    <%- include('partials/nav.ejs') %>

        <div class="d-flex justify-content-between mt-3" style="margin: 0px 15px;">
            <div>
                <h3>Welcome to Admin Dashboard</h3>
            </div>
            <div>
                <a href="/admin/dashboard/add" class="btn btn-primary">Add Blogs</a>
            </div>
        </div>

        <hr>

        <div class="container">

            <table class="table table-bordered align-middle text-center">

                <thead class="table-dark">
                    <tr>
                        <th>Sr.no</th>
                        <th>Title</th>
                        <th>Content</th>
                        <th>Author</th>
                        <th>Image</th>
                        <th>View</th>
                        <th>Update</th>
                        <th>Delete</th>
                    </tr>
                </thead>

                <tbody>

                    <% if (blogs && blogs.length> 0) { %>

                        <% blogs.forEach((blog, index)=> { %>

                            <tr>

                                <!-- ✅ FIXED SERIAL NUMBER -->
                                <td>
                                    <%= index + 1 %>
                                </td>

                                <td>
                                    <%= blog.title %>
                                </td>

                                <td>
                                    <%= blog.content.length> 100
                                        ? blog.content.slice(0, 80) + "..."
                                        : blog.content %>
                                </td>

                                <td>
                                    <%= blog.author %>
                                </td>

                                <td>
                                    <% if (blog.image) { %>
                                        <img src="<%= blog.image %>" width="80" height="60" style="object-fit:cover;">
                                        <% } else { %>
                                            No Image
                                            <% } %>
                                </td>

                                <td>
                                    <a href="/admin/dashboard/<%= blog._id %>">View</a>
                                </td>

                                <td>
                                    <a href="/admin/dashboard/update/<%= blog._id %>">Update</a>
                                </td>

                                <td>
                                    <form action="/admin/dashboard/delete/<%= blog._id %>" method="POST">
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                </td>

                            </tr>

                            <% }) %>

                                <% } else { %>

                                    <tr>
                                        <td colspan="8">No blogs found</td>
                                    </tr>

                                    <% } %>

                </tbody>

            </table>

            <!-- ================= PAGINATION ================= -->
            <nav>
                <ul class="pagination justify-content-center">

                    <!-- Previous -->
                    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                        <a href="?page=<%= page - 1 %>" class="page-link">Previous</a>
                    </li>

                    <!-- Current Page -->
                    <li class="page-item active">
                        <span class="page-link">
                            <%= page %>
                        </span>
                    </li>

                    <!-- Next -->
                    <li class="page-item">
                        <a href="?page=<%= page + 1 %>" class="page-link">Next</a>
                    </li>

                </ul>
            </nav>

        </div>

</body>

</html>