<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard For Admin</title>

    <link rel="stylesheet" href="/css/style.css">
    <%- include('partials/head.ejs') %>
</head>

<body>

    <%- include('partials/nav.ejs') %>

        <div class="d-flex justify-content-between mt-3" style="margin: 0px 15px;">
            <div>
                <h3>Welcome to Admin Dashboard</h3>
            </div>
            <div>
                <a href="/admin/dashboard/add" class="btn btn-primary">Add Blogs</a>
            </div>
        </div>

        <hr>

        <div class="container">
            <table class="table table-bordered align-middle text-center">

                <% if (blogs && blogs.length> 0) { %>

                    <thead class="table-dark">
                        <tr>
                            <th>Sr.no</th>
                            <th>Title</th>
                            <th>Content</th>
                            <th>Author</th>
                            <th>Image</th>
                            <th>View</th>
                            <th>Update</th>
                            <th>Delete</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% blogs.forEach((blog, index)=> { %>
                            <tr>
                                <td>
                                    <%= startSerial + index %>
                                </td>

                                <td>
                                    <%= blog.title %>
                                </td>

                                <td>
                                    <%= blog.content.length> 100
                                        ? blog.content.slice(0, 80) + "..."
                                        : blog.content %>
                                </td>

                                <td>
                                    <%= blog.author %>
                                </td>

                                <!-- ✅ IMAGE COLUMN -->
                                <td>
                                    <% if (blog.image) { %>
                                        <img src="<%= blog.image %>" alt="blog image" width="80" height="60"
                                            style="object-fit: cover; border-radius: 5px;">
                                        <% } else { %>
                                            <span>No Image</span>
                                            <% } %>
                                </td>

                                <!-- VIEW -->
                                <td>
                                    <a href="/admin/dashboard/<%= blog._id %>">
                                        <img src="https://tse3.mm.bing.net/th?id=OIP.JVnbhT3t9Xo13oxbQgwI_QHaHa&pid=Api&P=0&h=220"
                                            height="25">
                                    </a>
                                </td>

                                <!-- UPDATE -->
                                <td>
                                    <a href="/admin/dashboard/update/<%= blog._id %>">
                                        <img src="https://tse2.mm.bing.net/th?id=OIP._9--JKGbpacSeqRt8PA33QHaHa&pid=Api&P=0&h=220"
                                            height="25">
                                    </a>
                                </td>

                                <!-- DELETE -->
                                <td>
                                    <form action="/admin/dashboard/delete/<%= blog._id %>" method="POST"
                                        style="display:inline;">

                                        <button type="button" class="btn" data-bs-toggle="modal"
                                            data-bs-target="#deleteModal<%= blog._id %>">
                                            <img src="https://tse1.mm.bing.net/th?id=OIP.k0m2i2jTSw2J89geV7CROAHaHk&pid=Api&P=0&h=220"
                                                height="25">
                                        </button>

                                        <!-- Modal -->
                                        <div class="modal fade" id="deleteModal<%= blog._id %>" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content">

                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Confirm Delete</h5>
                                                        <button type="button" class="btn-close"
                                                            data-bs-dismiss="modal"></button>
                                                    </div>

                                                    <div class="modal-body">
                                                        Are you sure you want to delete:
                                                        <strong>
                                                            <%= blog.title %>
                                                        </strong> ?
                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary"
                                                            data-bs-dismiss="modal">Cancel</button>

                                                        <button type="button" class="btn btn-danger"
                                                            onclick="this.closest('form').submit()">Delete</button>
                                                    </div>

                                                </div>
                                            </div>
                                        </div>

                                    </form>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>

                    <% } else { %>
                        <tr>
                            <td colspan="8">No blogs found.</td>
                        </tr>
                        <% } %>

            </table>

            <!-- Pagination -->
            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item">
                        <a href="?page=<%= page - 1 %>" class="page-link">Previous</a>
                    </li>
                    <li class="page-item">
                        <a href="?page=<%= page + 1 %>" class="page-link">Next</a>
                    </li>
                </ul>
            </nav>

        </div>

</body>

</html>