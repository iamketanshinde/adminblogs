<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Update blog</title>

  <%- include('partials/head.ejs') %>
</head>

<body>

  <h1 class="mt-3 mx-4">Update blog</h1>

  <div class="container">

    <!-- IMPORTANT: enctype added -->
    <form action="/admin/dashboard/update/<%= blog._id %>" method="POST" enctype="multipart/form-data">

      <!-- TITLE -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" name="title" class="form-control" value="<%= blog.title %>" required>
      </div>

      <!-- CURRENT IMAGE -->
      <div class="mb-3">
        <label class="form-label">Current Image</label><br>

        <% if (blog.image) { %>
          <img src="<%= blog.image %>" width="150" style="border-radius:8px; margin-bottom:10px;">
          <% } else { %>
            <p>No Image</p>
            <% } %>
      </div>

      <!-- NEW IMAGE UPLOAD -->
      <div class="mb-3">
        <label class="form-label">Change Image</label>
        <input type="file" name="profileImage" class="form-control">
      </div>

      <!-- CONTENT -->
      <div class="mb-3">
        <label class="form-label">Content</label>
        <textarea class="form-control" rows="5" name="content" required><%= blog.content %></textarea>
      </div>

      <!-- AUTHOR -->
      <div class="mb-3">
        <label class="form-label">Author</label>
        <input type="text" name="author" class="form-control" value="<%= blog.author %>" required>
      </div>

      <a href="/admin/dashboard" class="btn btn-secondary">Back</a>
      <button type="submit" class="btn btn-primary">Update</button>

    </form>

  </div>

</body>

</html>